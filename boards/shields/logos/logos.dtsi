#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    kscan0: kscan0 {
        compatible = "zmk,kscan-gpio-matrix";

        diode-direction = "col2row";

        row-gpios
            = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;

        col-gpios
            = <&xiao_d 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };

    keymap_transform_0: keymap_transform_0 {
        compatible = "zmk,matrix-transform";

        columns = <10>;
        rows = <5>;
        map = <
                            RC(0,3) RC(0,2) RC(0,1) RC(0,0)   RC(3,5) RC(3,6) RC(0,7) RC(0,8)
            RC(1,4) RC(0,4) RC(1,3) RC(1,2) RC(1,1) RC(1,0)   RC(0,5) RC(2,6) RC(1,7) RC(1,8) RC(0,9) RC(1,9) 
            RC(2,4) RC(3,4) RC(2,3) RC(2,2) RC(2,1) RC(2,0)   RC(1,5) RC(0,6) RC(2,7) RC(2,8) RC(3,9) RC(2,9)
                                            RC(3,1) RC(3,0)   RC(2,5) RC(1,6) 
        >;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";

        display-name = "Default layout";
        transform = <&keymap_transform_0>; 
        kscan = <&kscan0>;
        keys  //                     w    h     x     y   rot   rx   ry
            //
            // TOP ROW  (left: pinky→index, right: index→pinky)
            //
            = <&key_physical_attrs 100 100  200    0     0    0    0>  // k0  RC(0,3) L top-pinky
            , <&key_physical_attrs 100 100  300    0     0    0    0>  // k1  RC(0,2) L top-ring
            , <&key_physical_attrs 100 100  400    0     0    0    0>  // k2  RC(0,1) L top-middle
            , <&key_physical_attrs 100 100  500    0     0    0    0>  // k3  RC(0,0) L top-index
            , <&key_physical_attrs 100 100  650    0     0    0    0>  // k4  RC(3,5) R top-index
            , <&key_physical_attrs 100 100  750    0     0    0    0>  // k5  RC(3,6) R top-middle
            , <&key_physical_attrs 100 100  850    0     0    0    0>  // k6  RC(0,7) R top-ring
            , <&key_physical_attrs 100 100  950    0     0    0    0>  // k7  RC(0,8) R top-pinky
            //
            // HOME ROW  (cluster pair first on each side, then pinky→index / index→pinky)
            //
            , <&key_physical_attrs 100 100    0  100     0    0    0>  // k8  RC(1,4) L cluster-home upper
            , <&key_physical_attrs 100 100  100  100     0    0    0>  // k9  RC(0,4) L cluster-home lower
            , <&key_physical_attrs 100 100  200  100     0    0    0>  // k10 RC(1,3) L home-pinky
            , <&key_physical_attrs 100 100  300  100     0    0    0>  // k11 RC(1,2) L home-ring
            , <&key_physical_attrs 100 100  400  100     0    0    0>  // k12 RC(1,1) L home-middle
            , <&key_physical_attrs 100 100  500  100     0    0    0>  // k13 RC(1,0) L home-index
            , <&key_physical_attrs 100 100  650  100     0    0    0>  // k14 RC(0,5) R home-index
            , <&key_physical_attrs 100 100  750  100     0    0    0>  // k15 RC(2,6) R home-middle
            , <&key_physical_attrs 100 100  850  100     0    0    0>  // k16 RC(1,7) R home-ring
            , <&key_physical_attrs 100 100  950  100     0    0    0>  // k17 RC(1,8) R home-pinky
            , <&key_physical_attrs 100 100 1050  100     0    0    0>  // k18 RC(0,9) R cluster-home upper
            , <&key_physical_attrs 100 100 1150  100     0    0    0>  // k19 RC(1,9) R cluster-home lower
            //
            // BOTTOM ROW  (cluster pair first on each side, then pinky→index / index→pinky)
            //
            , <&key_physical_attrs 100 100    0  200     0    0    0>  // k20 RC(2,4) L cluster-bot upper
            , <&key_physical_attrs 100 100  100  200     0    0    0>  // k21 RC(3,4) L cluster-bot lower
            , <&key_physical_attrs 100 100  200  200     0    0    0>  // k22 RC(2,3) L bot-pinky
            , <&key_physical_attrs 100 100  300  200     0    0    0>  // k23 RC(2,2) L bot-ring
            , <&key_physical_attrs 100 100  400  200     0    0    0>  // k24 RC(2,1) L bot-middle
            , <&key_physical_attrs 100 100  500  200     0    0    0>  // k25 RC(2,0) L bot-index
            , <&key_physical_attrs 100 100  650  200     0    0    0>  // k26 RC(1,5) R bot-index
            , <&key_physical_attrs 100 100  750  200     0    0    0>  // k27 RC(0,6) R bot-middle
            , <&key_physical_attrs 100 100  850  200     0    0    0>  // k28 RC(2,7) R bot-ring
            , <&key_physical_attrs 100 100  950  200     0    0    0>  // k29 RC(2,8) R bot-pinky
            , <&key_physical_attrs 100 100 1050  200     0    0    0>  // k30 RC(3,9) R cluster-bot upper
            , <&key_physical_attrs 100 100 1150  200     0    0    0>  // k31 RC(2,9) R cluster-bot lower
            //
            // THUMB ROW  (left: outer→inner, right: inner→outer)
            //
            , <&key_physical_attrs 100 100  400  300     0    0    0>  // k32 RC(3,1) L thumb-outer
            , <&key_physical_attrs 100 100  500  300     0    0    0>  // k33 RC(3,0) L thumb-inner
            , <&key_physical_attrs 100 100  650  300     0    0    0>  // k34 RC(2,5) R thumb-inner
            , <&key_physical_attrs 100 100  750  300     0    0    0>  // k35 RC(1,6) R thumb-outer
            ;
    };

    wired_split: wired_split {
        compatible = "zmk,wired-split";
        device = <&xiao_serial>;
    };
};

&xiao_serial {
    status = "okay";
};
